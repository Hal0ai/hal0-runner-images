# hal0-comfyui build pins — sourced by CI, passed as --build-arg to the Dockerfile.
#
# The torch triple MUST share one nightly date (ABI-matched). The *_REF values
# MUST be pinned to real commit SHAs before a release build — the values below
# marked TODO are still floating branch names and are NOT release-ready.

# AMD TheRock nightly index for gfx1151 (native wheels; no HSA spoofing).
ROCM_INDEX=https://rocm.nightlies.amd.com/v2/gfx1151/

# ABI-matched PyTorch triple. IMPORTANT: the nightly index rotates python tags
# by date — a given date only ships SOME cpXX wheels. The base venv here is
# python3.13 (cp313), so the date must have a cp313 wheel for ALL THREE. Verified
# 20260501 = latest common cp313 date (20260513 exists but is cp310/cp312/cp314
# only — no cp313 — which is why an earlier 20260513 pin failed to install).
# To bump: find the latest date present as cp313 for torch+vision+audio together.
TORCH_VER=2.9.1+rocm7.13.0a20260501
VISION_VER=0.24.0+rocm7.13.0a20260501
AUDIO_VER=2.9.0+rocm7.13.0a20260501

# Base image, digest-pinned (fedora:rawhide is a moving tag; this is the
# rawhide multi-arch index digest as of 2026-07-19). Bump by re-resolving
# registry.fedoraproject.org/fedora:rawhide.
FEDORA_BASE=registry.fedoraproject.org/fedora@sha256:7c96770c3676e4e61a3c0e258f7488c1ac723557ff4c10a24a0125ae330d0e10

# ComfyUI + custom nodes — pinned to commit SHAs (resolved 2026-07-19 HEADs).
COMFYUI_REF=c9602625e445e9ee37d3ac6faf5ea9ec1e0de87e        # comfyanonymous/ComfyUI (2026-07-19)
ESSENTIALS_REF=9d9f4bedfc9f0321c19faf71855e228c93bd0dc9     # cubiq/ComfyUI_essentials (2025-04-14)
AMDGPUMONITOR_REF=0c584ed28ed3678d96f631a6eff91be397c0baa4  # kyuz0/ComfyUI-AMDGPUMonitor (2025-11-23)
GGUF_REF=6ea2651e7df66d7585f6ffee804b20e92fb38b8a           # city96/ComfyUI-GGUF (2026-01-12)
