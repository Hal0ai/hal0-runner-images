# hal0-comfyui build pins — sourced by CI, passed as --build-arg to the Dockerfile.
#
# The torch triple MUST share one nightly date (ABI-matched). The *_REF values
# MUST be pinned to real commit SHAs before a release build — the values below
# marked TODO are still floating branch names and are NOT release-ready.

# AMD TheRock nightly index for gfx1151 (native wheels; no HSA spoofing).
ROCM_INDEX=https://rocm.nightlies.amd.com/v2/gfx1151/

# ABI-matched PyTorch triple (same nightly date across all three).
TORCH_VER=2.9.1+rocm7.13.0a20260513
VISION_VER=0.24.0+rocm7.13.0a20260513
AUDIO_VER=2.9.0+rocm7.13.0a20260513

# ComfyUI + custom nodes — TODO: replace branch names with pinned SHAs.
COMFYUI_REF=master          # TODO pin: github.com/comfyanonymous/ComfyUI
ESSENTIALS_REF=main         # TODO pin: github.com/cubiq/ComfyUI_essentials
AMDGPUMONITOR_REF=main      # TODO pin: github.com/kyuz0/ComfyUI-AMDGPUMonitor
GGUF_REF=main               # TODO pin: github.com/city96/ComfyUI-GGUF
